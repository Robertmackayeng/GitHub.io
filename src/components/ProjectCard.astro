---
interface Props {
  title: string;
  description: string;
  codeLink?: string;
  demoLink?: string;
}

const { title, description, codeLink, demoLink } = Astro.props;
---

<div class="bg-white border border-gray-200 rounded-lg p-8 transition-all duration-300 hover:shadow-lg hover:-translate-y-2">
  <div class="mb-4 pb-4 border-b-2 border-primary">
    <h3 class="text-primary text-2xl font-semibold">{title}</h3>
  </div>
  <p class="text-gray-600 mb-6 leading-relaxed">{description}</p>
  <div class="flex gap-4">
    {codeLink && (
      <a href={codeLink} class="project-link">View Code</a>
    )}
    {demoLink && (
      <a href={demoLink} class="project-link">Live Demo</a>
    )}
  </div>
</div>
